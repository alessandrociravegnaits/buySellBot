# ============================================
# buySellBot - Variabili d'ambiente (template)
# ============================================

# --- BINANCE ---
# Per TESTNET usa: https://testnet.binance.vision/
BINANCE_API_KEY=inserisci_qui_la_tua_api_key
BINANCE_API_SECRET=inserisci_qui_il_tuo_api_secret
BINANCE_TESTNET=true

# --- TELEGRAM ---
# Ottieni da: @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=inserisci_qui_il_token_botfather
# Ottieni il chat_id avviando @userinfobot
TELEGRAM_ALLOWED_USER_ID=inserisci_il_tuo_chat_id

# --- DATABASE ---
DB_PATH=./data/orders.db

# --- MCP TOKENS (per .vscode/mcp.json) ---
GITHUB_PAT=inserisci_github_pat
SENTRY_TOKEN=inserisci_sentry_auth_token
SENTRY_DSN=inserisci_sentry_dsn_del_progetto

# --- MONITOR BTC ---
BTC_MONITOR_ENABLED=true
BTC_RAPID_CHANGE_THRESHOLD=0.5
BTC_MONITOR_INTERVAL=1
